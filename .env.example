# FeBo Environment Variables
# Copy this file to .env and fill in your values

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=true

# FeBo Configuration
FEBO_NAME=FeBo
DEVELOPMENT_STAGE=3

# Memory & Persistence
MEMORY_DB_PATH=terminal/data/memory.db
MEMORY_JSONL_PATH=terminal/data/memories.jsonl

# Optional (for future tool use or external integrations)
# API keys should stay here, never commit them
# ANTHROPIC_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# Logging
LOG_LEVEL=INFO
LOG_FILE=terminal/logs/febo.log